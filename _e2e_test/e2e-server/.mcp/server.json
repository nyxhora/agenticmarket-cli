{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.test/e2e-server",
  "title": "E2e Server",
  "description": "E2E test server",
  "version": "1.0.0",
  "repository": {
    "url": "https://github.com/test/e2e-server",
    "source": "github"
  },
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://your-server.yourdomain.com/mcp"
    }
  ],
  "security": {
    "secretHeader": "x-mcp-secret"
  },
  "_meta": {
    "dev.agenticmarket": {
      "scaffoldedWith": "agenticmarket-create",
      "category": "utilities",
      "publishUrl": "https://agenticmarket.dev/dashboard/submit"
    }
  }
}
