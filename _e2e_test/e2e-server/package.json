{
  "name": "e2e-server",
  "version": "1.0.0",
  "description": "E2E test server",
  "mcpName": "io.github.test/e2e-server",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup src/index.ts --format esm --dts",
    "start": "node --env-file=.env dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector tsx --env-file=.env src/index.ts",
    "test:tools": "npx @modelcontextprotocol/inspector --cli tsx --env-file=.env src/index.ts",
    "validate": "npx agenticmarket validate",
    "release": "npm version patch && npx agenticmarket publish"
  },
  "dependencies": {
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "fetch-to-node": "^2.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
