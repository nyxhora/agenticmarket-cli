# ── Server Secrets ────────────────────────────────────────
MCP_SECRET=
MCP_SECRET_HEADER=x-mcp-secret

# ── Server Config ─────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS (comma-separated origins) ───────────────────────
CORS_ORIGINS=

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
