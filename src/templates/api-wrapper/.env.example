# ── Server Secrets ────────────────────────────────────────
MCP_SECRET=
MCP_SECRET_HEADER=x-mcp-secret

# ── API Configuration ──────────────────────────────────────
API_BASE_URL=__API_BASE_URL__
API_KEY=
API_AUTH_HEADER=__AUTH_HEADER__
API_TIMEOUT_MS=10000

# ── Server Config ─────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── CORS (comma-separated origins) ───────────────────────
CORS_ORIGINS=

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
